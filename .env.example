# Database
DATABASE_URL="postgresql://user:password@localhost:5432/clutch_social_tracker"

# NextAuth
NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# YouTube Data API v3
YOUTUBE_API_KEY=""

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=""
INSTAGRAM_APP_ID=""
