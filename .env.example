# Scraping Configuration (Twitter, TikTok)
PLAYWRIGHT_HEADLESS="true"
SCRAPE_DELAY_MS="3000"
SCRAPE_MAX_RETRIES="3"

# SMTP (for email notifications)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Cron Security (for automated sync trigger)
CRON_SECRET_TOKEN="generate-a-random-token"
