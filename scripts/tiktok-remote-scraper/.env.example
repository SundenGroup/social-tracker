# Clutch Social Tracker — TikTok Remote Scraper
# Copy this to .env and fill in values

# Production API URL
API_URL=https://social.clutch.game

# Same token as CRON_SECRET_TOKEN on the server
API_TOKEN=your-api-token-here

# TikTok accounts to scrape (comma-separated, without @)
# Single account:   TIKTOK_USERNAMES=pubg.esports.official
# Multiple accounts: TIKTOK_USERNAMES=pubg.esports.official,pubgesportsturkiye
TIKTOK_USERNAMES=pubg.esports.official

# Legacy single-account setting (still supported as fallback)
# TIKTOK_USERNAME=pubg.esports.official

# TikTok session cookies (from browser DevTools)
# Format: "sessionid=abc123; sessionid_ss=abc123; uid_tt=xyz"
TIKTOK_COOKIES=

# Max videos to scrape per account per run
MAX_VIDEOS=200

# Retry settings (for scheduled/unattended runs)
# Number of attempts before giving up
MAX_RETRIES=3
# Minutes to wait between retries
RETRY_DELAY_MIN=5
