# Clutch Social Tracker — TikTok Remote Scraper
# Copy this to .env and fill in values

# Production API URL
API_URL=https://social.clutch.game

# Same token as CRON_SECRET_TOKEN on the server
API_TOKEN=080748ff97267cb25a8e496c236e56e4e4edbe84cacac9724b9c35d537e49cdd

# TikTok account to scrape (without @)
TIKTOK_USERNAME=pubg.esports.official

# TikTok session cookies (from browser DevTools)
# Format: "sessionid=abc123; sessionid_ss=abc123; uid_tt=xyz"
TIKTOK_COOKIES=

# Max videos to scrape per run
MAX_VIDEOS=200
